---
import { siteConfig } from '../../data/site';
import { mainNavigation } from '../../data/navigation';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16 lg:h-20" aria-label="Main navigation">
      <!-- Logo -->
      <a
        href="/"
        class="flex items-center gap-2 text-brand-green font-heading text-xl font-extrabold tracking-tight hover:text-brand-green-light transition-colors"
      >
        <span class="text-2xl">⛳</span>
        <span>MOSTY</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-8">
        {mainNavigation.map((item) => (
          item.children ? (
            <div class="relative group">
              <button class="flex items-center gap-1 text-sm font-medium text-text-light hover:text-brand-green transition-colors py-2">
                {item.label}
                <svg class="w-3 h-3 opacity-50" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M1 1l4 4 4-4" />
                </svg>
              </button>
              <div class="absolute top-full left-0 mt-1 bg-white rounded-lg shadow-lg border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2 flex">
                <div class="w-48">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-sm text-text-light hover:text-brand-green hover:bg-brand-cream/50 transition-colors"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
                {item.image && (
                  <div class="w-48 p-3 border-l border-gray-100 bg-brand-cream/30 rounded-r-lg flex items-center justify-center">
                    <img src={item.image} alt="Featured product" class="w-full h-auto object-contain rounded-lg" width="200" height="200" loading="lazy" />
                  </div>
                )}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="text-sm font-medium text-text-light hover:text-brand-green transition-colors"
            >
              {item.label}
            </a>
          )
        ))}
      </div>

      <!-- CTA + Mobile Menu Button -->
      <div class="flex items-center gap-3">
        <a
          href={siteConfig.amazonStoreUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="hidden sm:inline-flex items-center gap-1.5 px-4 py-2 bg-cta text-white text-sm font-semibold rounded-lg hover:bg-cta-hover transition-colors shadow-sm"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 22.5C6.21 22.5 1.5 17.79 1.5 12S6.21 1.5 12 1.5 22.5 6.21 22.5 12 17.79 22.5 12 22.5z"/>
            <circle cx="9" cy="9" r="2" fill="white"/>
            <circle cx="14" cy="8" r="2" fill="white"/>
          </svg>
          Shop Amazon
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden p-2 text-text-light hover:text-brand-green transition-colors"
          aria-label="Toggle menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            <path id="menu-icon-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6L6 18" />
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-3 space-y-1">
      {mainNavigation.map((item) => (
        item.children ? (
          <details class="group">
            <summary class="flex items-center justify-between py-2 text-sm font-medium text-text-light cursor-pointer hover:text-brand-green transition-colors">
              {item.label}
              <svg class="w-3 h-3 opacity-50" viewBox="0 0 10 6" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M1 1l4 4 4-4" />
              </svg>
            </summary>
            <div class="pl-4 pb-1 space-y-1">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block py-1.5 text-sm text-text-muted hover:text-brand-green transition-colors"
                >
                  {child.label}
                </a>
              ))}
            </div>
          </details>
        ) : (
          <a
            href={item.href}
            class="block py-2 text-sm font-medium text-text-light hover:text-brand-green transition-colors"
          >
            {item.label}
          </a>
        )
      ))}
      <a
        href={siteConfig.amazonStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="block mt-3 px-4 py-2.5 bg-cta text-white text-sm font-semibold rounded-lg text-center hover:bg-cta-hover transition-colors"
      >
        Shop on Amazon →
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
  });
</script>
