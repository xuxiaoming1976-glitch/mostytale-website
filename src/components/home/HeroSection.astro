---
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<section class="relative overflow-hidden bg-gradient-to-br from-brand-green-dark to-brand-green text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-12 py-12 md:py-20 lg:py-24">
      <!-- Left: Text Content -->
      <div class="flex-1 max-w-xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full text-sm font-medium mb-8">
          <span class="w-2 h-2 bg-brand-gold rounded-full animate-pulse"></span>
          Trusted by 5,000+ golfers worldwide
        </div>

        <!-- Heading -->
        <h1 class="text-display text-white mb-6 animate-fade-in">
          {siteConfig.tagline}
        </h1>

        <!-- Subtitle -->
        <p class="text-lg md:text-xl text-white/90 leading-relaxed mb-10">
          Professional-grade golf cleaning accessories that keep your gear in championship condition.
          Designed for golfers who demand the best from their equipment.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <Button
            href={siteConfig.amazonStoreUrl}
            variant="amazon"
            size="lg"
            external
            class="!bg-cta !text-white hover:!bg-cta-hover"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M13.5 2.5c-1.7 0-3.3.8-4.3 2.1-.2.2-.1.5.1.6.2.1.5 0 .6-.2.8-1.1 2.1-1.8 3.6-1.8 2.5 0 4.5 2 4.5 4.5s-2 4.5-4.5 4.5c-1.5 0-2.8-.7-3.6-1.8-.1-.2-.4-.3-.6-.2-.2.1-.3.4-.1.6 1 1.3 2.6 2.1 4.3 2.1 2.9 0 5.3-2.4 5.3-5.3 0-2.8-2.3-5.1-5.3-5.1z"/>
              <path d="M22.1 19.7c-.3-.7-1.1-1.2-2.3-1.6-.9-.3-2-.5-3.2-.6l-1.3-.1c-.3 0-.5.2-.5.5s.2.5.5.5l1.3.1c1.1.1 2.1.3 2.9.5 1.1.3 1.7.7 1.9 1.1.2.4.2.9-.1 1.4-.7 1.2-2.7 2.1-5.7 2.6-.3 0-.5.3-.5.6s.3.5.6.5c3.2-.5 5.4-1.5 6.2-2.9.4-.7.5-1.5.2-2.2z"/>
              <path d="M7.2 21.1c.8-.5 1.4-1.3 1.7-2.2.2-.6.2-1.2 0-1.8-.2-.5-.4-.9-.7-1.3-.5-.6-1.1-1-1.8-1.2l-.7-.2c-.3-.1-.5.1-.6.3-.1.3.1.5.3.6l.7.2c.5.2 1 .5 1.3.9.2.3.4.6.5 1 .1.4.1.9 0 1.3-.2.7-.6 1.2-1.2 1.6-.3.2-.5.6-.3 1 .2.3.6.5 1 .3z"/>
              <path d="M15 21c-.7 0-1.4-.2-1.9-.6-.3-.2-.7-.2-.9.1-.2.3-.1.7.1.9.7.5 1.6.8 2.6.8.5 0 .9-.4.9-.9 0-.2-.1-.3-.3-.3h-.5z"/>
            </svg>
            Shop on Amazon
          </Button>
          <Button href="/products/" variant="outline" size="lg" class="!border-white/30 !text-white hover:!bg-white hover:!text-brand-green">
            View Products →
          </Button>
        </div>

        <!-- Stats row -->
        <div class="flex flex-wrap gap-8 mt-12 pt-8 border-t border-white/20">
          <div>
            <div class="text-2xl font-bold text-brand-gold">{siteConfig.stats.customersServed.toLocaleString()}+</div>
            <div class="text-sm text-white/70">Happy Golfers</div>
          </div>
          <div>
            <div class="text-2xl font-bold text-brand-gold">{siteConfig.stats.productsSold.toLocaleString()}+</div>
            <div class="text-sm text-white/70">Products Sold</div>
          </div>
          <div class="flex items-start gap-2">
            <div class="text-2xl font-bold text-brand-gold">{siteConfig.stats.averageRating}★</div>
            <div class="text-sm text-white/70">Average Rating<br/>({siteConfig.stats.reviewCount.toLocaleString()}+ reviews)</div>
          </div>
        </div>
      </div>

      <!-- Right: Product Image -->
      <div class="flex-1 w-full lg:w-auto">
        <img
          src="/images/products/hero-bg.jpg"
          alt="MOSTY Golf Club Cleaner Bag - Premium Golf Cleaning Kit"
          class="w-full h-auto rounded-2xl shadow-2xl object-contain"
          loading="eager"
          width="2928"
          height="1200"
        />
      </div>
    </div>
  </div>
</section>
