---
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
  <div class="text-center md:text-left group">
    <div class="w-14 h-14 bg-brand-green/10 rounded-2xl flex items-center justify-center mb-5 mx-auto md:mx-0 group-hover:bg-brand-green/20 transition-colors">
      <svg class="w-7 h-7 text-brand-green" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
      </svg>
    </div>
    <h3 class="text-xl font-heading font-semibold text-text mb-3">Innovation</h3>
    <p class="text-text-light leading-relaxed mb-4">
      Our 2-in-1 design combines club and ball cleaning in one compact tool. Engineered for speed, portability, and performance on every hole.
    </p>
    <a href="/products/cleaning/" class="inline-flex items-center gap-1 text-sm font-medium text-brand-green hover:text-brand-green-light transition-colors">
      Explore cleaning series <span class="text-lg">→</span>
    </a>
  </div>

  <div class="text-center md:text-left group">
    <div class="w-14 h-14 bg-brand-green/10 rounded-2xl flex items-center justify-center mb-5 mx-auto md:mx-0 group-hover:bg-brand-green/20 transition-colors">
      <svg class="w-7 h-7 text-brand-green" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
      </svg>
    </div>
    <h3 class="text-xl font-heading font-semibold text-text mb-3">Quality</h3>
    <p class="text-text-light leading-relaxed mb-4">
      Premium waterproof TPU, scratch-free microfiber, and heavy-duty 600D polyester. Every product is built to last season after season.
    </p>
    <a href={siteConfig.amazonStoreUrl} class="inline-flex items-center gap-1 text-sm font-medium text-cta hover:text-cta-hover transition-colors" target="_blank" rel="noopener noreferrer">
      Read Amazon reviews <span class="text-lg">→</span>
    </a>
  </div>

  <div class="text-center md:text-left group">
    <div class="w-14 h-14 bg-brand-green/10 rounded-2xl flex items-center justify-center mb-5 mx-auto md:mx-0 group-hover:bg-brand-green/20 transition-colors">
      <svg class="w-7 h-7 text-brand-green" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
      </svg>
    </div>
    <h3 class="text-xl font-heading font-semibold text-text mb-3">Portable</h3>
    <p class="text-text-light leading-relaxed mb-4">
      Lightweight, clip-on designs that go wherever your game takes you. From the driving range to cross-country trips, MOSTY travels with you.
    </p>
    <a href="/products/" class="inline-flex items-center gap-1 text-sm font-medium text-brand-green hover:text-brand-green-light transition-colors">
      View all products <span class="text-lg">→</span>
    </a>
  </div>
</div>
