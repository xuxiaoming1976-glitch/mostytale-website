---
import { reviews } from '../../data/reviews';
import StarRating from '../ui/StarRating.astro';

const featuredReviews = reviews.slice(0, 6);
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {featuredReviews.map((review) => (
    <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
      <!-- Header -->
      <div class="flex items-center gap-3 mb-3">
        <div class="w-10 h-10 bg-brand-green text-white rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">
          {review.author.charAt(0)}
        </div>
        <div class="min-w-0">
          <div class="font-medium text-text text-sm truncate">{review.author}</div>
          <div class="flex items-center gap-1.5">
            <StarRating rating={review.rating} size="sm" />
          </div>
        </div>
        {review.verified && (
          <span class="ml-auto flex-shrink-0 px-2 py-0.5 bg-green-50 text-green-700 text-xs rounded-full border border-green-200">
            Verified
          </span>
        )}
      </div>

      <!-- Title -->
      <h4 class="font-heading font-semibold text-text mb-2 text-sm">{review.title}</h4>

      <!-- Body -->
      <p class="text-sm text-text-light leading-relaxed line-clamp-4">{review.body}</p>

      <!-- Product -->
      <p class="mt-3 text-xs text-text-muted">Reviewed: {review.product}</p>
    </div>
  ))}
</div>
