---
export interface Props {
  rating: number;
  count?: number;
  size?: 'sm' | 'md';
}

const { rating, count, size = 'md' } = Astro.props;
const fullStars = Math.floor(rating);
const hasHalf = rating - fullStars >= 0.5;
const emptyStars = 5 - fullStars - (hasHalf ? 1 : 0);

const starSize = size === 'sm' ? 'w-3.5 h-3.5' : 'w-5 h-5';
---

<span class="inline-flex items-center gap-0.5" aria-label={`${rating} out of 5 stars`}>
  {Array.from({ length: fullStars }).map(() => (
    <svg class={`${starSize} text-amber-400`} fill="currentColor" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
  ))}
  {hasHalf && (
    <svg class={`${starSize} text-amber-400`} fill="currentColor" viewBox="0 0 20 20">
      <defs>
        <linearGradient id="half-star">
          <stop offset="50%" stop-color="currentColor" />
          <stop offset="50%" stop-color="#D1D5DB" />
        </linearGradient>
      </defs>
      <path fill="url(#half-star)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
  )}
  {Array.from({ length: emptyStars }).map(() => (
    <svg class={`${starSize} text-gray-300`} fill="currentColor" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
  ))}
  {count && (
    <span class="ml-1.5 text-sm text-text-muted">({count})</span>
  )}
</span>
