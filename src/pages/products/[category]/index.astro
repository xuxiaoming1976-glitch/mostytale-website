---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import ProductCard from '../../../components/products/ProductCard.astro';
import { categories, getProductsByCategory } from '../../../data/products';
import type { Product } from '../../../data/products';

export function getStaticPaths() {
  return categories.map((cat) => ({
    params: { category: cat.slug },
    props: {
      category: cat,
      products: getProductsByCategory(cat.slug),
    },
  }));
}

interface Props {
  category: (typeof categories)[number];
  products: Product[];
}

const { category, products } = Astro.props;
---

<BaseLayout
  title={category.name}
  description={category.description}
>
  <Section background="green" padding="sm">
    <div class="py-4">
      <a href="/products/" class="inline-flex items-center gap-1 text-white/70 text-sm hover:text-white transition-colors mb-4">
        ← Back to All Products
      </a>
      <h1 class="text-h1 text-white mb-3">{category.name}</h1>
      <p class="text-white/80 text-lg max-w-2xl">{category.description}</p>
    </div>
  </Section>

  <Section background="white">
    {products.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {products.map((product, i) => (
          <ProductCard product={product} index={i} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <div class="text-6xl mb-4">🔜</div>
        <h2 class="text-2xl font-heading font-semibold text-text mb-2">Coming Soon</h2>
        <p class="text-text-muted max-w-md mx-auto">
          We're working on new products for this category. Check back soon or follow us on social media for updates.
        </p>
      </div>
    )}
  </Section>
</BaseLayout>
