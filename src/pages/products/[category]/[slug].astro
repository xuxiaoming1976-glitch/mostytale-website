---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Section from '../../../components/ui/Section.astro';
import Button from '../../../components/ui/Button.astro';
import StarRating from '../../../components/ui/StarRating.astro';
import { products, getProductBySlug, getProductsByCategory } from '../../../data/products';
import { generateProductSchema } from '../../../utils/seo';
import type { Product } from '../../../data/products';

export function getStaticPaths() {
  return products.map((product) => ({
    params: {
      category: product.category,
      slug: product.slug,
    },
    props: { product },
  }));
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
const productSchema = generateProductSchema({
  name: product.name,
  description: product.shortDescription,
  images: product.images,
  amazonUrl: product.amazonUrl,
  rating: product.rating,
  reviewCount: product.reviewCount,
});
const relatedProducts = getProductsByCategory(product.category)
  .filter((p) => p.slug !== product.slug)
  .slice(0, 3);

const featureIcons: Record<string, string> = {
  droplet: '💧',
  layers: '📐',
  shield: '🛡️',
  briefcase: '💼',
  zap: '⚡',
  maximize: '📏',
  link: '🔗',
  'rotate-cw': '🔄',
  truck: '🚛',
  lock: '🔒',
  package: '📦',
  feather: '🪶',
  grid: '📊',
  anchor: '⚓',
  folder: '📁',
};
---

<BaseLayout
  title={product.name}
  description={product.shortDescription}
  image={product.images[0]}
  type="product"
  schema={productSchema}
  canonicalURL={`/products/${product.category}/${product.slug}/`}
>
  <Section background="white" padding="sm">
    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-sm text-text-muted mb-8 flex-wrap">
      <a href="/" class="hover:text-brand-green transition-colors">Home</a>
      <span>/</span>
      <a href="/products/" class="hover:text-brand-green transition-colors">Products</a>
      <span>/</span>
      <a href={`/products/${product.category}/`} class="hover:text-brand-green transition-colors capitalize">
        {product.category === 'cleaning' ? 'Cleaning' : product.category === 'golf-bags' ? 'Golf Bags' : 'Accessories'}
      </a>
      <span>/</span>
      <span class="text-text">{product.name}</span>
    </nav>

    <!-- Product Hero -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
      <!-- Image Gallery -->
      <div>
        <div class="aspect-square bg-gradient-to-br from-brand-cream to-gray-50 rounded-2xl overflow-hidden mb-4">
          {product.images[0] ? (
            <img
              src={product.images[0]}
              alt={product.name}
              class="w-full h-full object-contain p-8"
              width="600"
              height="600"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center text-8xl text-brand-gold/20">
              ⛳
            </div>
          )}
        </div>
        {product.images.length > 1 && (
          <div class="grid grid-cols-4 gap-3">
            {product.images.slice(1).map((img, i) => (
              <div class="aspect-square bg-brand-cream rounded-xl overflow-hidden">
                <img src={img} alt={`${product.name} view ${i + 2}`} class="w-full h-full object-contain p-3" width="150" height="150" loading="lazy" />
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Product Info -->
      <div>
        <span class="inline-block px-3 py-1 bg-brand-green/10 text-brand-green text-sm font-medium rounded-full capitalize mb-4">
          {product.category === 'cleaning' ? 'Cleaning' : product.category === 'golf-bags' ? 'Golf Bags' : 'Accessories'}
        </span>
        <h1 class="text-h1 text-text mb-2">{product.name}</h1>
        <p class="text-xl text-brand-gold font-medium mb-4">{product.tagline}</p>

        <!-- Rating -->
        <div class="flex items-center gap-3 mb-6">
          <StarRating rating={product.rating} />
          <span class="text-text-light text-sm">{product.rating} ({product.reviewCount} reviews on Amazon)</span>
        </div>

        <!-- Description -->
        <p class="text-text-light leading-relaxed mb-8 text-base">{product.description}</p>

        <!-- Amazon CTA -->
        <a
          href={product.amazonUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 px-8 py-4 bg-cta text-white font-bold text-lg rounded-xl hover:bg-cta-hover transition-all shadow-lg hover:shadow-xl"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M13.5 2.5c-1.7 0-3.3.8-4.3 2.1-.2.2-.1.5.1.6.2.1.5 0 .6-.2.8-1.1 2.1-1.8 3.6-1.8 2.5 0 4.5 2 4.5 4.5s-2 4.5-4.5 4.5c-1.5 0-2.8-.7-3.6-1.8-.1-.2-.4-.3-.6-.2-.2.1-.3.4-.1.6 1 1.3 2.6 2.1 4.3 2.1 2.9 0 5.3-2.4 5.3-5.3 0-2.8-2.3-5.1-5.3-5.1z"/>
          </svg>
          Buy on Amazon
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>

        <p class="mt-3 text-xs text-text-muted">
          Ships fast with Amazon Prime. 30-day return guarantee.
        </p>
      </div>
    </div>
  </Section>

  <!-- Features -->
  <Section background="cream" id="features">
    <h2 class="text-h2 text-text text-center mb-12">Key Features</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {product.features.map((feat) => (
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <div class="text-3xl mb-3">{featureIcons[feat.icon] || '✅'}</div>
          <h3 class="font-heading font-semibold text-text mb-2">{feat.title}</h3>
          <p class="text-sm text-text-light leading-relaxed">{feat.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- How It Works -->
  <Section background="white" id="how-it-works">
    <h2 class="text-h2 text-text text-center mb-12">How It Works</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      {product.howItWorks
        .sort((a, b) => a.step - b.step)
        .map((step) => (
          <div class="text-center relative">
            <div class="w-14 h-14 bg-brand-green text-white rounded-full flex items-center justify-center mx-auto mb-4 text-xl font-bold">
              {step.step}
            </div>
            <h3 class="font-heading font-semibold text-text mb-2">{step.title}</h3>
            <p class="text-sm text-text-light leading-relaxed">{step.description}</p>
          </div>
        ))}
    </div>
  </Section>

  <!-- Specs + What's Included -->
  <Section background="cream" id="specs">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- Specs -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
        <h3 class="font-heading font-semibold text-lg text-text mb-6">Specifications</h3>
        <dl class="space-y-3">
          {Object.entries(product.specs).map(([key, value]) => (
            <div class="flex justify-between py-2 border-b border-gray-100 last:border-0">
              <dt class="text-sm text-text-muted capitalize">{key}</dt>
              <dd class="text-sm font-medium text-text">{value}</dd>
            </div>
          ))}
        </dl>
      </div>

      <!-- What's Included -->
      <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-100">
        <h3 class="font-heading font-semibold text-lg text-text mb-6">What's Included</h3>
        <ul class="space-y-3">
          {product.whatIsIncluded.map((item) => (
            <li class="flex items-start gap-3 text-sm text-text-light">
              <span class="text-brand-green mt-0.5">✓</span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <!-- Bottom CTA -->
  <Section background="green" padding="md">
    <div class="text-center">
      <h2 class="text-h2 text-white mb-4">Ready to Try the {product.name}?</h2>
      <p class="text-white/80 text-lg max-w-xl mx-auto mb-8">
        Available now on Amazon with fast, free Prime shipping.
      </p>
      <a
        href={product.amazonUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-cta text-white font-bold text-lg rounded-xl hover:bg-cta-hover transition-all shadow-lg hover:shadow-xl"
      >
        Buy on Amazon →
      </a>
    </div>
  </Section>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <Section background="white">
      <h2 class="text-h2 text-text text-center mb-12">You Might Also Like</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {relatedProducts.map((p) => (
          <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm hover:shadow-md transition-all hover:-translate-y-1">
            <div class="aspect-square bg-brand-cream rounded-lg mb-4 overflow-hidden">
              {p.images[0] ? (
                <img src={p.images[0]} alt={p.name} class="w-full h-full object-contain p-4" width="200" height="200" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-4xl text-brand-gold/20">⛳</div>
              )}
            </div>
            <h3 class="font-heading font-semibold text-text mb-1">{p.name}</h3>
            <p class="text-xs text-text-muted line-clamp-2 mb-3">{p.shortDescription}</p>
            <a href={`/products/${p.category}/${p.slug}/`} class="text-sm font-medium text-brand-green hover:text-brand-green-light transition-colors">
              View Details →
            </a>
          </div>
        ))}
      </div>
    </Section>
  )}
</BaseLayout>
